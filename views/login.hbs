<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Login – Scheduling System</title>

<style>
* { box-sizing: border-box; margin: 0; padding: 0; }

body {
    font-family: Arial;
    background: #f4f4f4;
    display: flex;
    justify-content: center;
    align-items: center;
    height: 100vh;
}

.card {
    background: #fff;
    padding: 2rem;
    width: 100%;
    max-width: 360px;
    border-radius: 8px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
}

h1 {
    margin-bottom: 1.5rem;
    text-align: center;
}

input {
    width: 100%;
    padding: 10px;
    margin: 10px 0;
}

button {
    width: 100%;
    padding: 10px;
    background: #4a90d9;
    color: white;
    border: none;
}

.error {
    background: #fdecea;
    color: red;
    padding: 8px;
    margin-bottom: 10px;
}
</style>
</head>

<body>

<div class="card">
<h1>Scheduling System</h1>

{{#if error}}
<div class="error">{{error}}</div>
{{/if}}

{{!-- STEP 1: LOGIN --}}
{{#if (eq step "password")}}
<form method="POST" action="/login">
    
    <input type="text" name="username" placeholder="Username" required>
    
    <input type="password" name="password" placeholder="Password" required>

    <button type="submit">Login</button>

</form>
{{/if}}

{{!-- STEP 2: OTP --}}
{{#if (eq step "2fa")}}
<form method="POST" action="/verify-2fa">

    <p>{{message}}</p>

    <input type="hidden" name="username" value="{{username}}">
    <input type="hidden" name="tempSessionId" value="{{tempSessionId}}">

    <input type="text" name="code" placeholder="Enter 6-digit code" required>

    <button type="submit">Verify OTP</button>

</form>
{{/if}}

</div>

</body>
</html>