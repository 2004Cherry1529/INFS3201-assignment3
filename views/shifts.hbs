<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Shifts – Scheduling System</title>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { font-family: Arial, sans-serif; background: #f4f4f4; color: #333; }
        header { background: #4a90d9; color: #fff; padding: 1rem 2rem; display: flex; justify-content: space-between; align-items: center; }
        header h1 { font-size: 1.3rem; }
        .user-bar { display: flex; align-items: center; gap: 1rem; font-size: 0.9rem; }
        .logout-btn { background: rgba(255,255,255,0.2); border: 1px solid rgba(255,255,255,0.5); color: #fff; padding: 0.35rem 0.8rem; border-radius: 4px; cursor: pointer; font-size: 0.85rem; }
        .logout-btn:hover { background: rgba(255,255,255,0.3); }
        main { max-width: 900px; margin: 2rem auto; padding: 0 1rem; }
        .nav-tabs { display: flex; gap: 0.5rem; margin-bottom: 1.5rem; }
        .tab { padding: 0.45rem 1.1rem; border-radius: 4px; font-size: 0.9rem; text-decoration: none; background: #e0e0e0; color: #555; }
        .tab.active { background: #4a90d9; color: #fff; }
        .tab:hover:not(.active) { background: #ccc; }
        .page-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem; }
        .page-header h2 { font-size: 1.2rem; }
        .btn { padding: 0.4rem 1rem; border-radius: 4px; font-size: 0.9rem; text-decoration: none; border: none; cursor: pointer; display: inline-block; }
        .btn-primary { background: #4a90d9; color: #fff; }
        .btn-primary:hover { background: #357abd; }
        table { width: 100%; border-collapse: collapse; background: #fff; border-radius: 8px; overflow: hidden; box-shadow: 0 1px 4px rgba(0,0,0,0.08); }
        th { background: #4a90d9; color: #fff; text-align: left; padding: 0.75rem 1rem; font-size: 0.9rem; }
        td { padding: 0.75rem 1rem; border-bottom: 1px solid #eee; font-size: 0.95rem; vertical-align: top; }
        tr:last-child td { border-bottom: none; }
        tr:hover td { background: #f9f9f9; }
        .badge { display: inline-block; padding: 0.2rem 0.5rem; border-radius: 3px; font-size: 0.75rem; margin: 1px; }
        .morning { background: #fff3cd; color: #856404; }
        .afternoon { background: #d1ecf1; color: #0c5460; }
        .emp-list { display: flex; flex-wrap: wrap; gap: 4px; }
        .emp-tag { background: #e8f0fe; color: #1a56db; padding: 0.15rem 0.5rem; border-radius: 3px; font-size: 0.8rem; }
        .empty-emps { color: #aaa; font-size: 0.85rem; font-style: italic; }
        .empty { text-align: center; padding: 2rem; color: #888; background: #fff; border-radius: 8px; box-shadow: 0 1px 4px rgba(0,0,0,0.08); }
        .success { background: #d4edda; color: #155724; padding: 0.6rem 1rem; border-radius: 4px; margin-bottom: 1rem; font-size: 0.9rem; }
        .error-msg { background: #fdecea; color: #c0392b; padding: 0.6rem 1rem; border-radius: 4px; margin-bottom: 1rem; font-size: 0.9rem; }
    </style>
</head>
<body>
    <header>
        <h1>Scheduling System</h1>
        <div class="user-bar">
            <span>Logged in as <strong>{{username}}</strong></span>
            <form method="POST" action="/logout" style="margin:0">
                <button class="logout-btn" type="submit">Log out</button>
            </form>
        </div>
    </header>

    <main>
        {{#if success}}<div class="success">{{success}}</div>{{/if}}
        {{#if errorMsg}}<div class="error-msg">{{errorMsg}}</div>{{/if}}

        <div class="nav-tabs">
            <a class="tab" href="/">Employees</a>
            <a class="tab active" href="/shifts">Shifts</a>
        </div>

        <div class="page-header">
            <h2>All Shifts</h2>
            <a class="btn btn-primary" href="/shifts/add">+ Add Shift</a>
        </div>

        {{#if shifts.length}}
        <table>
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Start</th>
                    <th>End</th>
                    <th>Type</th>
                    <th>Assigned Employees</th>
                </tr>
            </thead>
            <tbody>
                {{#each shifts}}
                <tr>
                    <td>{{date}}</td>
                    <td>{{startTime}}</td>
                    <td>{{endTime}}</td>
                    <td>
                        {{#if isMorning}}
                            <span class="badge morning">Morning</span>
                        {{else}}
                            <span class="badge afternoon">Afternoon</span>
                        {{/if}}
                    </td>
                    <td>
                        {{#if employeeDetails.length}}
                            <div class="emp-list">
                                {{#each employeeDetails}}
                                    <span class="emp-tag">{{name}}</span>
                                {{/each}}
                            </div>
                        {{else}}
                            <span class="empty-emps">No employees assigned</span>
                        {{/if}}
                    </td>
                </tr>
                {{/each}}
            </tbody>
        </table>
        {{else}}
            <div class="empty">No shifts yet. <a href="/shifts/add" style="color:#4a90d9">Add one</a>.</div>
        {{/if}}
    </main>
</body>
</html>
