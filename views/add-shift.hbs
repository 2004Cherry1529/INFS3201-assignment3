<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add Shift – Scheduling System</title>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { font-family: Arial, sans-serif; background: #f4f4f4; color: #333; }
        header { background: #4a90d9; color: #fff; padding: 1rem 2rem; display: flex; justify-content: space-between; align-items: center; }
        header h1 { font-size: 1.3rem; }
        .user-bar { display: flex; align-items: center; gap: 1rem; font-size: 0.9rem; }
        .logout-btn { background: rgba(255,255,255,0.2); border: 1px solid rgba(255,255,255,0.5); color: #fff; padding: 0.35rem 0.8rem; border-radius: 4px; cursor: pointer; font-size: 0.85rem; }
        .logout-btn:hover { background: rgba(255,255,255,0.3); }
        main { max-width: 480px; margin: 2rem auto; padding: 0 1rem; }
        a.back { color: #4a90d9; text-decoration: none; display: inline-block; margin-bottom: 1rem; font-size: 0.9rem; }
        a.back:hover { text-decoration: underline; }
        .card { background: #fff; border-radius: 8px; padding: 1.5rem; box-shadow: 0 1px 4px rgba(0,0,0,0.08); }
        h2 { font-size: 1.2rem; margin-bottom: 1.2rem; }
        label { display: block; font-size: 0.9rem; color: #555; margin-bottom: 4px; }
        input { width: 100%; padding: 0.6rem 0.8rem; border: 1px solid #ccc; border-radius: 4px; font-size: 1rem; margin-bottom: 1rem; }
        input:focus { outline: none; border-color: #4a90d9; }
        .hint { font-size: 0.78rem; color: #888; margin-top: -0.8rem; margin-bottom: 1rem; }
        .error-msg { background: #fdecea; color: #c0392b; padding: 0.6rem 0.8rem; border-radius: 4px; margin-bottom: 1rem; font-size: 0.9rem; }
        .row { display: flex; gap: 1rem; }
        .row > div { flex: 1; }
        .actions { display: flex; gap: 0.75rem; margin-top: 0.5rem; }
        .btn { padding: 0.5rem 1.2rem; border-radius: 4px; font-size: 0.95rem; border: none; cursor: pointer; text-decoration: none; display: inline-block; }
        .btn-primary { background: #4a90d9; color: #fff; }
        .btn-primary:hover { background: #357abd; }
        .btn-secondary { background: #e0e0e0; color: #333; }
        .btn-secondary:hover { background: #ccc; }
    </style>
</head>
<body>
    <header>
        <h1>Scheduling System</h1>
        <div class="user-bar">
            <span>Logged in as <strong>{{username}}</strong></span>
            <form method="POST" action="/logout" style="margin:0">
                <button class="logout-btn" type="submit">Log out</button>
            </form>
        </div>
    </header>

    <main>
        <a class="back" href="/shifts">← Back to shifts</a>

        <div class="card">
            <h2>Add Shift</h2>

            {{#if error}}
                <div class="error-msg">{{error}}</div>
            {{/if}}

            <form method="POST" action="/shifts/add">
                <label for="date">Date</label>
                <input type="date" id="date" name="date" value="{{formData.date}}" required>

                <div class="row">
                    <div>
                        <label for="startTime">Start Time</label>
                        <input type="time" id="startTime" name="startTime" value="{{formData.startTime}}" required>
                    </div>
                    <div>
                        <label for="endTime">End Time</label>
                        <input type="time" id="endTime" name="endTime" value="{{formData.endTime}}" required>
                    </div>
                </div>
                <p class="hint">End time must be after start time.</p>

                <div class="actions">
                    <button class="btn btn-primary" type="submit">Add Shift</button>
                    <a class="btn btn-secondary" href="/shifts">Cancel</a>
                </div>
            </form>
        </div>
    </main>
</body>
</html>
